{
  "name": "@wecode-ai/weibo-openclaw-plugin",
  "version": "2.1.0",
  "type": "module",
  "description": "OpenClaw Weibo DM channel plugin",
  "bin": {
    "weibo-openclaw-plugin": "./bin/install.js"
  },
  "scripts": {
    "test:unit": "vitest run",
    "ci:check": "npx tsc --noEmit && npm run test:unit",
    "build": "tsc && npm run pack:prepare",
    "pack:prepare": "node scripts/prepare-pack.js",
    "pack": "npm run build && cd dist && npm pack",
    "release": "npm run build && cd dist && npm publish --access public --registry=https://registry.npmjs.org/",
    "release:beta": "npm version prerelease --preid=beta --no-git-tag-version && npm run build && npm publish ./dist --tag beta --access public --registry=https://registry.npmjs.org/",
    "dev": "tsx",
    "sim:server": "tsx weibo-server.ts"
  },
  "license": "MIT",
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "channel": {
      "id": "weibo",
      "label": "Weibo",
      "selectionLabel": "Weibo (微博)",
      "docsPath": "/channels/weibo",
      "docsLabel": "weibo",
      "blurb": "Weibo direct message channel.",
      "order": 80
    }
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.48",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "bundledDependencies": [
    "@sinclair/typebox",
    "ws",
    "zod"
  ],
  "devDependencies": {
    "@types/node": "^25.0.10",
    "@types/ws": "^8.5.14",
    "@vitest/coverage-v8": "^2.1.8",
    "openclaw": "^2026.3.23",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.23"
  }
}
